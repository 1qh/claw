{
  "name": "uniclaw",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "lib/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "check": "lintmax check",
    "clean": "rm -rf node_modules bun.lock dist .cache .next .turbo packages/*/node_modules apps/*/node_modules lib/*/node_modules packages/*/dist apps/*/dist apps/*/.next",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "bun run --filter '@uniclaw/web' dev",
    "fix": "lintmax fix",
    "test": "bun test"
  },
  "dependencies": {
    "better-auth": "latest",
    "drizzle-orm": "latest",
    "openclaw": "latest",
    "postgres": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@tailwindcss/typography": "latest",
    "bun-types": "latest",
    "drizzle-kit": "latest",
    "lintmax": "latest",
    "tailwindcss": "latest",
    "tw-animate-css": "latest",
    "typescript": "latest"
  },
  "trustedDependencies": [
    "lintmax"
  ]
}
