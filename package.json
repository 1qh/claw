{
  "name": "claw",
  "private": true,
  "type": "module",
  "workspaces": ["lib/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "next dev --turbopack -p 3000",
    "dev:ws": "bun --watch src/server/ws.ts",
    "build": "next build",
    "check": "lintmax check",
    "fix": "lintmax fix",
    "clean": "rm -rf node_modules bun.lock .next dist .turbo",
    "test": "bun test",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.13.11",
    "@xterm/addon-fit": "latest",
    "@xterm/xterm": "latest",
    "better-auth": "latest",
    "drizzle-orm": "latest",
    "e2b": "latest",
    "elysia": "latest",
    "next": "latest",
    "postgres": "latest",
    "react": "latest",
    "react-dom": "latest",
    "ws": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/ws": "latest",
    "drizzle-kit": "latest",
    "lintmax": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  },
  "trustedDependencies": ["lintmax"]
}
